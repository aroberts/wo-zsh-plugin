#compdef wo
#autoload

local -a targets
targets=("${(@s/:/)${ZSH_WO_PATHS:-$HOME}}")

for t in $targets; do
  [[ -d $t ]] || continue
  local label=${t/#$HOME/\~}
  local -a group=()
  for dir in "$t"/*/(N:t); do
    group+=("$dir")
  done
  (( ${#group} )) && compadd -M 'm:{a-zA-Z}={A-Za-z}' -V "$label" -X $'%{\e[2m%}'"-- ${label}"$'%{\e[0m%}' -a group
done
